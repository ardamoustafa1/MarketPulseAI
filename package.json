{
  "name": "marketpulse-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "setup:local": "bash infra/scripts/bootstrap_local.sh",
    "demo:live": "bash infra/scripts/run_live_demo.sh",
    "seed:local": "cd apps/api && python3 -m app.db.seed",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:perf:k6": "k6 run tests/perf/k6-portfolio-benchmark.js",
    "infra:validate": "bash infra/scripts/validate_terraform.sh",
    "generate:api-types:admin": "openapi-typescript http://localhost:8000/api/v1/openapi.json -o apps/admin/src/api/generated.ts",
    "generate:api-types:mobile": "openapi-typescript http://localhost:8000/api/v1/openapi.json -o apps/mobile/src/api/generated.ts",
    "generate:api-types": "npm run generate:api-types:admin && npm run generate:api-types:mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "expo": "54.0.33",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.0.0",
    "turbo": "^1.11.0"
  },
  "overrides": {
    "react-native": "0.81.5",
    "@react-native/codegen": "0.81.5",
    "@react-native/babel-plugin-codegen": "0.81.5",
    "@react-native/virtualized-lists": "0.81.5",
    "@react-native/metro-config": "0.83.6",
    "@react-native/metro-babel-transformer": "0.83.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0"
  },
  "dependencies": {
    "semver": "^7.7.4",
    "webidl-conversions": "^8.0.1"
  }
}
