{
  "name": "marketpulse-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "expo": "54.0.33",
    "prettier": "^3.0.0",
    "turbo": "^1.11.0"
  },
  "overrides": {
    "react-native": "0.81.5",
    "@react-native/codegen": "0.81.5",
    "@react-native/babel-plugin-codegen": "0.81.5",
    "@react-native/virtualized-lists": "0.81.5",
    "@react-native/metro-config": "0.83.6",
    "@react-native/metro-babel-transformer": "0.83.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0"
  },
  "dependencies": {
    "semver": "^7.7.4",
    "webidl-conversions": "^8.0.1"
  }
}
