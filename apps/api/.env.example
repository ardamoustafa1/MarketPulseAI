# Database Configuration
DATABASE_URL=postgresql://marketpulse_user:secretpassword@localhost:5432/marketpulse_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Authentication
SECRET_KEY=super-secret-jwt-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Third-party APIs
OPENAI_API_KEY=your-openai-key-here
COINGECKO_API_KEY=your-coingecko-key-here

# Price Feed
PRICE_POLL_INTERVAL_SECONDS=5
PRICE_HTTP_TIMEOUT_SECONDS=8.0
PRICE_PROVIDER_MAX_RETRIES=2
PRICE_PROVIDER_RETRY_BACKOFF_SECONDS=0.4
# Comma separated with no spaces for docker/env convenience
PRICE_SYMBOLS=BTC,ETH,SOL,ADA,XRP,BNB,DOGE,TRX,DOT,MATIC,AVAX,LINK,LTC,BCH,ATOM,ETC,XLM,XMR,FIL,APT,ARB,OP,HBAR,VET,NEAR,ALGO,ICP,AAVE,SAND,MANA,USDTRY,EURUSD,GBPUSD,USDJPY,USDCHF,USDCAD,USDAUD,USDNZD,USDSEK,USDNOK,USDDKK,USDCNH,USDRUB,USDZAR,USDMXN,USDBRL,USDINR,USDKRW,USDHKD,USDSGD,USDPLN,USDCZK,USDHUF,USDILS,USDAED,USDSAR,USDQAR,USDKWD,USDBHD,USDOMR,USDTHB,USDMYR,USDIDR,USDPHP,USDVND,XAU,XAG,XPT,XPD
HAREM_API_BASE_URL=https://altinapi.com/api/v1
HAREM_API_KEY=
