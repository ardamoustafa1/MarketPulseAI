{
  "cli": {
    "version": ">= 11.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.YOUR_DOMAIN",
        "EXPO_PUBLIC_WS_URL": "wss://staging.YOUR_DOMAIN",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://YOUR_DOMAIN/privacy",
        "EXPO_PUBLIC_TERMS_URL": "https://YOUR_DOMAIN/terms",
        "EXPO_PUBLIC_SUPPORT_URL": "https://YOUR_DOMAIN/support"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.YOUR_DOMAIN",
        "EXPO_PUBLIC_WS_URL": "wss://api.YOUR_DOMAIN",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://YOUR_DOMAIN/privacy",
        "EXPO_PUBLIC_TERMS_URL": "https://YOUR_DOMAIN/terms",
        "EXPO_PUBLIC_SUPPORT_URL": "https://YOUR_DOMAIN/support"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "metadataPath": "./store.config.json"
      }
    }
  }
}
