ENVIRONMENT=development
POSTGRES_USER=marketpulse_user
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=marketpulse_db

SECRET_KEY=change-this-to-very-long-random-secret
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
JWT_ISSUER=marketpulse-api
JWT_AUDIENCE=marketpulse-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
WS_CONNECT_RATE_LIMIT_MAX_REQUESTS=30
WS_CONNECT_RATE_LIMIT_WINDOW_SECONDS=60

PRICE_POLL_INTERVAL_SECONDS=5
PRICE_HTTP_TIMEOUT_SECONDS=8.0
PRICE_PROVIDER_MAX_RETRIES=2
PRICE_PROVIDER_RETRY_BACKOFF_SECONDS=0.4
# Recommended free stack:
# ExchangeRate.host + Frankfurter (no API key), Twelve Data key optional.
PRICE_SYMBOLS=BTC,ETH,SOL,ADA,XRP,BNB,DOGE,TRX,DOT,MATIC,AVAX,LINK,LTC,BCH,ATOM,ETC,XLM,XMR,FIL,APT,ARB,OP,HBAR,VET,NEAR,ALGO,ICP,AAVE,SAND,MANA,USDTRY,EURUSD,GBPUSD,USDJPY,USDCHF,USDCAD,USDAUD,USDNZD,USDSEK,USDNOK,USDDKK,USDCNH,USDRUB,USDZAR,USDMXN,USDBRL,USDINR,USDKRW,USDHKD,USDSGD,USDPLN,USDCZK,USDHUF,USDILS,USDAED,USDSAR,USDQAR,USDKWD,USDBHD,USDOMR,USDTHB,USDMYR,USDIDR,USDPHP,USDVND,XAU,XAG,XPT,XPD
EXCHANGE_RATE_HOST_BASE_URL=https://open.er-api.com/v6
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1
GOLD_API_BASE_URL=https://api.gold-api.com/price
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
# Optional: https://twelvedata.com/
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
# Optional: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
APP_ROLE=all
PRICE_SCHEDULER_ENABLED=true
BILLING_WEBHOOK_SECRET=change-me-webhook-secret
ADMIN_STEP_UP_TOKEN=replace-with-strong-step-up-token
ADMIN_STEP_UP_TOTP_SECRET=replace-with-base32-totp-secret
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_HOPS=1
PUBLIC_SNAPSHOT_EXPIRE_HOURS=168
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_API_BASE_URL=https://api.openai.com/v1
